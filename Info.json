{
  "name": "Danmaku Cosmos",
  "identifier": "com.danmaku-cosmos.iina-plugin",
  "version": "1.0.0",
  "description": "IINA弹幕插件，支持Niconico和Bilibili格式，CSS/Canvas双渲染模式",
  "author": {
    "name": "karappo-yu"
  },
  "entry": "main.js",
  "globalEntry": "global.js",
  "permissions": [
    "show-osd",
    "show-alert",
    "video-overlay",
    "network-request",
    "file-system"
  ],
  "sidebarTab": {
    "name": "Danmaku"
  },
  "allowedDomains": ["*"],
  "preferencesPage": "preferences.html",
  "preferenceDefaults": {
    "danmakuEnabled": true,
    "danmakuOpacity": 0.7,
    "danmakuCanvasOpacity": 0.8,
    "danmakuFontScale": 1.0,
    "danmakuSpeed": 680,
    "scrollDuration": 8000,
    "blockForceLane": false,
    "maxLaneRatio": 1.0,
    "cssFontFamily": "default",
    "cssFontWeight": 800,
    "cssStrokeWidth": 0.16
  }
}
