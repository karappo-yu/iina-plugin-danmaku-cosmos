{
  "name": "Danmaku Cosmos",
  "identifier": "com.damaku-cosmos.iina-plugin",
  "version": "1.0.0",
  "description": "IINA弹幕显示插件，自动加载与视频同名的XML弹幕文件",
  "author": {
    "name": "Danmaku Cosmos"
  },
  "entry": "main.js",
  "globalEntry": "global.js",
  "permissions": [
    "show-osd",
    "show-alert",
    "video-overlay",
    "network-request",
    "file-system"
  ],
  "sidebarTab": {
    "name": "Danmaku"
  },
  "allowedDomains": ["*"],
  "preferenceDefaults": {
    "danmakuEnabled": true,
    "danmakuOpacity": 0.7,
    "danmakuFontScale": 1.0,
    "danmakuSpeed": 680,
    "scrollDuration": 8000,
    "maxDanmakuPerSecond": 0
  }
}
